# Token du bot obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=123456:ABCdef_ton_token_ici

# --- WhatsApp (Meta Cloud API) — optionnel ---------------------------------
# Renseigner les 3 premières variables active le canal WhatsApp au démarrage.
# WHATSAPP_TOKEN=EAAG...                 # token permanent Graph API
# WHATSAPP_PHONE_NUMBER_ID=123456789     # id du numéro expéditeur
# WHATSAPP_VERIFY_TOKEN=une_chaine_secrete   # doit correspondre au champ saisi
#                                            # dans la config webhook Meta
# WHATSAPP_APP_SECRET=...                 # secret de l'app (vérif signature HMAC)
# WHATSAPP_WEBHOOK_HOST=0.0.0.0          # interface d'écoute du webhook
# WHATSAPP_WEBHOOK_PORT=8080             # port d'écoute du webhook
